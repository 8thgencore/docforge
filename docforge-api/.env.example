APP_NAME=DocForge RAG
ENVIRONMENT=dev
API_V1_PREFIX=/v1
API_KEY=change-me
CORS_ALLOW_ORIGINS=http://localhost:5173

DB_NAME=docforge
DB_USER=docforge
DB_PASSWORD=docforge
DB_HOST=
DB_PORT=5432

REDIS_PASSWORD=change-me-redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0

QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_COLLECTION=docforge_chunks

###############################################################

LLM_PROVIDER= # ollama, lmstudio, openai

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=bge-m3

LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_CHAT_MODEL=qwen2.5:7b-instruct
LMSTUDIO_EMBED_MODEL=text-embedding-qwen3-embedding-4b

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.1-codex-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

###############################################################

STORAGE_PATH=./data/storage
UPLOAD_PATH=./data/uploads

MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP=200
DEFAULT_TOP_K=8
LOW_CONFIDENCE_THRESHOLD=0.35

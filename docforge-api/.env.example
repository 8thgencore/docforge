APP_NAME=DocForge RAG
ENVIRONMENT=dev
API_V1_PREFIX=/v1
API_KEY=change-me

DB_NAME=docforge
DB_USER=docforge
DB_PASSWORD=docforge
DB_HOST=
DB_PORT=5432

REDIS_PASSWORD=change-me-redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0

QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_COLLECTION=docforge_chunks

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=bge-m3

STORAGE_PATH=./data/storage
UPLOAD_PATH=./data/uploads

MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP=200
DEFAULT_TOP_K=8
LOW_CONFIDENCE_THRESHOLD=0.35
